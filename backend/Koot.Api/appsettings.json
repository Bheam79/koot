{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=koot;User=koot;Password=koot;"
  },
  "Jwt": {
    "Issuer": "KootApi",
    "Audience": "KootClient",
    "Key": "CHANGE_ME_SUPER_SECRET_KEY_AT_LEAST_32_CHARS_LONG_FOR_HS256",
    "ExpiryDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://localhost:31180",
      "http://koot.ai.ba.gl:31143",
      "http://localhost:443"
    ]
  },
  "RateLimiting": {
    "Login": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "Register": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    },
    "Upload": {
      "PermitLimit": 60,
      "WindowSeconds": 3600
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/koot-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  }
}
